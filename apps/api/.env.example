# API environment template. Copy to .env.local for dev, do NOT commit.
# See `apps/api/src/lib/env.ts` for the typed loader.

# ── Supabase ─────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service-role JWT — bypasses RLS. Rotate often; do NOT keep this on disk
# in production. In Vercel, set it as a project env var instead.
SUPABASE_SERVICE_ROLE_KEY=

# Deep-link target for email verify + password reset.
PUBLIC_APP_URL=learnbuddy://
EMAIL_REDIRECT_URL=learnbuddy://verify-email

# DSGVO consent version currently in effect (Doc 09 §consent).
DSGVO_CONSENT_VERSION=2026-05-01

# ── Vertex AI ────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=
GOOGLE_VERTEX_LOCATION=europe-west4
VERTEX_MODEL_ID=gemini-2.5-flash-lite

# ── RevenueCat webhook ───────────────────────────────────────────────────
# Paste the same string in the RevenueCat dashboard (Project → Webhooks).
REVENUECAT_WEBHOOK_SECRET=

# ── Admin allowlist ──────────────────────────────────────────────────────
# Comma-separated list of admin email addresses. The /admin/* routes
# require both a valid Supabase JWT AND the JWT's email to appear here.
ADMIN_ALLOWLIST_EMAILS=

# ── Dev tools ────────────────────────────────────────────────────────────
# Set to 'true' in local dev to enable DELETE /dev/nuke-account (hard-deletes
# the current user from Supabase Auth + all cascaded DB rows). NEVER set in
# staging or production — the route won't even exist if this is unset/false.
ENABLE_DEV_ROUTES=true

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Defaults to local dev origins when unset.
API_CORS_ORIGINS=

# ── Observability ────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_RELEASE=
