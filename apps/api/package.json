    "@hono/zod-validator": "^0.4.2",
    "@learnbuddy/shared-math": "workspace:*",
    "@learnbuddy/shared-types": "workspace:*",
    "@sentry/node": "^10.53.1",
    "@supabase/supabase-js": "^2.47.10",
    "hono": "^4.6.14",
    "jsonrepair": "^3.14.0",
    "katex": "^0.16.47",
    "mathjs": "^14.9.1",
    "sharp": "^0.34.5",
    "ts-fsrs": "^4.7.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "@types/node": "^22.10.0",
