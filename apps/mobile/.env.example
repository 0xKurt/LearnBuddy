# Mobile environment template. Copy to .env.local for dev, do NOT commit.
# All `EXPO_PUBLIC_*` values are bundled into the JS at build time
# (Expo Router convention) — do NOT put secrets here that you wouldn't
# happily ship in the IPA / APK.

# ── API ──────────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:6001

# ── Supabase ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── DSGVO ────────────────────────────────────────────────────────────────
EXPO_PUBLIC_DSGVO_CONSENT_VERSION=2026-05-01

# ── RevenueCat ───────────────────────────────────────────────────────────
# Public API key — safe to ship in the bundle.
EXPO_PUBLIC_REVENUECAT_API_KEY=

# ── Observability ────────────────────────────────────────────────────────
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
EXPO_PUBLIC_APP_RELEASE=dev
