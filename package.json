{
  "name": "learnbuddy",
  "version": "0.0.0",
  "private": true,
  "description": "LearnBuddy — AI learning companion. See docs/.",
  "engines": {
    "node": ">=22 <27",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r --parallel test",
    "build": "pnpm -r --parallel build",
    "prepare": "husky",
    "db:start": "cd infra/supabase && supabase start",
    "db:stop": "cd infra/supabase && supabase stop",
    "db:reset": "cd infra/supabase && supabase db reset",
    "db:wipe": "cd infra/supabase && supabase db execute --project-ref mjwsrmnugzbmcwingpey --file wipe-dev-data.sql"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
